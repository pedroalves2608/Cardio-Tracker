# Opcional: usuário e senha para login (padrão: admin / admin)
LOGIN_USER=admin
LOGIN_PASSWORD=admin

# OBRIGATÓRIO em produção: chave secreta forte para o JWT (gere uma com: openssl rand -base64 32)
# Se não definir em produção, o app recusa requisições de sessão.
SESSION_SECRET=cardio-secret-change-me

# Email (Esqueci a senha): chave da API Resend (https://resend.com). Se não definir, em dev o link volta no JSON.
# RESEND_API_KEY=re_xxxx
# Opcional: remetente (ex: noreply@seudominio.com). Em teste pode usar onboarding@resend.dev
# RESEND_FROM=Cardio Tracker <onboarding@resend.dev>

# Rate limit (login): em produção com várias instâncias, use Upstash Redis para compartilhar contagem.
# Crie um banco em https://upstash.com e defina:
# UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=AXxx...

# Produção: use um banco remoto (PostgreSQL). Ex: Vercel Postgres, Neon, Supabase.
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
